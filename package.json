    "@dnd-kit/utilities": "^3.2.2",
    "adm-zip": "^0.5.18",
    "ai": "^7.0.15",
    "drizzle-orm": "^0.45.2",
    "jsonrepair": "^3.15.0",
    "next": "16.2.10",
    "pg-boss": "^12.25.1",
