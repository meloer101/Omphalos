# Supabase local stack (see `supabase status` after `pnpm supabase:start`)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# 物理只读角色（db/migrations/0003_readonly_role.sql）——留给 P2 检索
# 合同用，P1 建好待用。见 Agent架构设计.md 5.2"安全靠构造，不靠模型自觉"。
DATABASE_URL_READONLY="postgresql://graph_readonly:graph_readonly_dev_only@127.0.0.1:54322/postgres"

# Phase 3 决策 J（拆库）：独立测试库，仅 vitest 使用。dev/dogfooding 走上面的
# DATABASE_URL（主库 postgres），测试走这里的 pmeverything_test——这样 pnpm test
# 的 TRUNCATE 永远碰不到积累数周的 dogfooding 图。db/client.ts 在 VITEST 下强制
# 用这两个，缺失即报错；resetGraph() 还有一道"库名必须含 _test"的护栏兜底。
#   建库：CREATE DATABASE pmeverything_test;（本地一次性）
#   迁移：pnpm db:migrate:test
DATABASE_URL_TEST="postgresql://postgres:postgres@127.0.0.1:54322/pmeverything_test"
DATABASE_URL_READONLY_TEST="postgresql://graph_readonly:graph_readonly_dev_only@127.0.0.1:54322/pmeverything_test"

# Phase 3 决策 K：dogfooding 指标埋点开关。默认 on（不设或非 "false" 即开）；
# 设为 "false" 时 emitEvent 静默 no-op，产品功能不受影响（PRD Non-Goal"遥测可关"）。
# 指标全部留在本地 Postgres 的 events 表，不外发（贴合自部署/数据敏感定位）。
TELEMETRY_ENABLED="true"

# LiteLLM proxy — OpenAI-compatible endpoint in front of DeepSeek.
# Phase 0.4 spikes this connectivity; not used until then.
LITELLM_BASE_URL="http://127.0.0.1:4000"
LITELLM_API_KEY="sk-litellm-local"
DEEPSEEK_API_KEY=""

# P2 语义索引用本地 embedding（Phase2-开工计划.md 决策 E 修订）：litellm/
# config.yaml 的 `embedding` 别名指向宿主机 Ollama 的 bge-m3（1024 维），
# 数据不出内网、无需任何 API key。前置：`ollama pull bge-m3` + Ollama 在跑。
